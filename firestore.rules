rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
        (request.auth.token.email == "kamauwanyiri54@gmail.com" && request.auth.token.email_verified == true)
      );
    }

    // Admissions
    match /admissions/{admissionId} {
      allow create: if true; // Allow public applications
      allow read, update, delete: if isAdmin();
    }

    // News
    match /news/{newsId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Progress Reports
    match /progress/{progressId} {
      allow read: if isAuthenticated() && (isAdmin() || request.auth.uid == resource.data.studentId);
      allow write: if isAdmin();
    }

    // Users
    match /users/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }
  }
}
